COMPOSE_PROJECT_NAME=hermes-runtime

# Docker 内网网段:必须显式固定,避免 Docker 自动分配撞上内网真实设备(曾撞 172.22)。
RUNTIME_SUBNET=172.31.240.0/24

# Bootstrap tags. Run deploy/scripts/lock-images.sh deploy/.env before compose up;
# the script writes immutable repo digests to deploy/images.lock.env.
POSTGRES_IMAGE=postgres:15.13-bookworm
# auto-setup 1.29.x still ships tctl (compose healthcheck and verify-pipeline.sh
# depend on it). tctl was removed from server images in 1.30.1; migrate the
# healthcheck and verifier to the temporal CLI before bumping this tag.
TEMPORAL_IMAGE=temporalio/auto-setup:1.29.6
TEMPORAL_UI_IMAGE=temporalio/ui:2.49.1
GO_IMAGE=golang:1.26.5-bookworm
RUNTIME_BASE_IMAGE=alpine:3.22.1
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
RUNTIME_IMAGE_TAG=dev

POSTGRES_ADMIN_USER=temporal_admin
POSTGRES_ADMIN_PASSWORD=
RUNTIME_DB_USER=hermes_runtime
RUNTIME_DB_PASSWORD=

GITLAB_BASE_URL=https://gitlab2.quectel.com
GITLAB_TOKEN=
GITLAB_TOKEN_HEADER=PRIVATE-TOKEN
PACKAGE_NAME=algo-super-sdk
TRIGGER_WEBHOOK_SECRET=
TRIGGER_REFS=master

TRIGGER_BIND_IP=0.0.0.0
TRIGGER_HOST_PORT=18090
# 决策 2(UAT LAN 暴露):worker callbacks 绑测试网段供 Windows Client 回调;
# 缩小暴露面时改回 127.0.0.1。
WORKER_CALLBACKS_BIND_IP=0.0.0.0
WORKER_CALLBACKS_HOST_PORT=18091
TEMPORAL_UI_HOST_PORT=18080

# MinIO 证据直传(§3.7)。9000 绑测试网段(bind IP 变量化),控制台 9001 仅 localhost。
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=hermes-evidence
MINIO_PRESIGN_TTL=1h
# 预签名 URL 的 host,须为 Client 可达地址(签名覆盖 Host,不可事后改写)。
MINIO_PUBLIC_ENDPOINT=http://10.88.118.251:9000
MINIO_BIND_IP=0.0.0.0
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001

# q-uat default: callbacks 已按决策 2 暴露到测试网段,Windows Client 与服务器
# 同网段,此 URL 指向服务器 LAN 地址。仅在测试网段使用;Phase 3 mTLS 落地前
# 不得暴露到更大范围。
CALLBACK_BASE_URL=http://10.88.118.251:18091
ARTIFACT_AUTH_TYPE=bearer
ARTIFACT_AUTH_TOKEN=
FEISHU_WEBHOOK_URL=
